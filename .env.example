# Copy to .env and fill in values from https://salla.partners after creating your app.

SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=

# Public URL of THIS backend (where Salla redirects after auth). Must equal the
# Callback URL configured in the Partners portal, minus the path.
# In dev, use the ngrok/cloudflared URL that Salla can reach.
BACKEND_URL=https://your-backend-tunnel.ngrok-free.app

# Public URL of the frontend. Backend redirects here after a successful install.
FRONTEND_URL=http://localhost:3001

# Space-separated scopes. Start read-only; add more later.
# Required for the full workflow:
#   - products.read              (catalog sync)
#   - settings.read              (resolve store_id after install via /store/info)
#   - customers.read_write       (provision a Salla customer at checkout, deduct loyalty points)
#   - orders.read_write          (create orders at checkout)
#   - shippings.read             (auto-pick a courier for shipping orders)
#   - payments.read              (filter accepted_methods to what merchant enables)
#   - marketing.read_write       (create one-time coupons for loyalty redemption)
#   - loyalties.read_write       (read the merchant's points-to-currency rate)
#   - offline_access             (issue refresh tokens)
SALLA_SCOPES="offline_access products.read settings.read customers.read_write orders.read_write shippings.read payments.read marketing.read_write loyalties.read_write"

# Postgres. Railway provisions this automatically when you add the Postgres
# add-on and link it to the souq service — it injects DATABASE_URL into your
# env. For local dev, point at any Postgres (e.g. via `docker run postgres`).
DATABASE_URL="postgresql://user:password@host:5432/souq?schema=public"

# Backend HTTP port.
PORT=3000

# Customer-session signing key. Generate with `openssl rand -hex 32` (or any
# 32+ char random string). REQUIRED in production — server will refuse to
# sign sessions without it. Never share this; never commit it.
JWT_SECRET=
