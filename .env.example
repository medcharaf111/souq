# Copy to .env and fill in values from https://salla.partners after creating your app.

SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=

# Public URL of THIS backend (where Salla redirects after auth). Must equal the
# Callback URL configured in the Partners portal, minus the path.
# In dev, use the ngrok/cloudflared URL that Salla can reach.
BACKEND_URL=https://your-backend-tunnel.ngrok-free.app

# Public URL of the frontend. Backend redirects here after a successful install.
FRONTEND_URL=http://localhost:3001

# Space-separated scopes. Start read-only; add more later.
SALLA_SCOPES="offline_access products.read settings.read"

# Postgres. Railway provisions this automatically when you add the Postgres
# add-on and link it to the souq service — it injects DATABASE_URL into your
# env. For local dev, point at any Postgres (e.g. via `docker run postgres`).
DATABASE_URL="postgresql://user:password@host:5432/souq?schema=public"

# Backend HTTP port.
PORT=3000
