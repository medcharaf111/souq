generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  storeId      String    @id
  storeName    String?
  storeDomain  String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  installedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?
  products     Product[]
}

model Product {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [storeId], onDelete: Cascade)
  sallaId         String
  name            String
  sku             String?
  description     String?
  priceAmount     Float
  priceCurrency   String
  salePriceAmount Float?
  quantity        Int?
  status          String
  type            String?
  productUrl      String?
  imageUrl        String?
  raw             String
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cartItems       CartItem[]

  @@unique([storeId, sallaId])
  @@index([storeId, status])
  @@index([storeId, syncedAt])
  @@index([name])
}

// ─── Customer-side (shoppers on one merchant's branded app) ──────────────────
// Each customer belongs to exactly one merchant. Same email can register
// independently on different merchants — they're separate accounts. There is
// no cross-merchant identity by design.

model Customer {
  id              String   @id @default(cuid())
  storeId         String   // which merchant this customer shops with
  email           String
  phone           String?
  name            String?
  passwordHash    String
  sallaCustomerId String?  // filled in lazily on first purchase intent (Phase B)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cart            Cart?

  @@unique([storeId, email])
  @@index([storeId])
}

model Cart {
  id         String     @id @default(cuid())
  customerId String     @unique
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  storeId    String     // denormalized — same as customer's storeId, indexed here for queries
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([storeId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  qty       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}
